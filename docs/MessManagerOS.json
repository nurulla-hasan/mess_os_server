{
  "info": {
    "_postman_id": "2b7d6c7f-0f6f-4f62-9e5b-7c1a2b1f8f0a",
    "name": "MessManagerOS API (v1)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "messId", "value": "" },
    { "key": "memberId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "expenseId", "value": "" },
    { "key": "billingCycleId", "value": "" },
    { "key": "requestId", "value": "" },
    { "key": "billId", "value": "" },
    { "key": "scheduleId", "value": "" },
    { "key": "planId", "value": "" },
    { "key": "listId", "value": "" },
    { "key": "noticeId", "value": "" },
    { "key": "complaintId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) pm.collectionVariables.set('baseUrl', 'http://localhost:5000');",
          "if (!pm.collectionVariables.get('accessToken')) pm.collectionVariables.set('accessToken', '');"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"01700000000\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register",
            "description": "Role: Public"
          }
        },
        {
          "name": "Login (Saves accessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "try { const json = pm.response.json(); const token = json?.data?.accessToken; if (token) pm.collectionVariables.set('accessToken', token); } catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "Role: Public"
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/verify-email",
            "description": "Role: Public"
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/resend-otp",
            "description": "Role: Public"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/refresh-token",
            "description": "Role: Public (requires refreshToken cookie)"
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/logout",
            "description": "Role: Public"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/forgot-password",
            "description": "Role: Public"
          }
        },
        {
          "name": "Verify Reset OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/verify-reset-otp",
            "description": "Role: Public"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"password1234\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/reset-password",
            "description": "Role: Public"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"oldPassword\": \"password123\",\n  \"newPassword\": \"password1234\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/change-password",
            "description": "Role: Auth"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        { "name": "Get Me", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/users/me", "description": "Role: Auth" } },
        {
          "name": "Update Me",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Updated Name\",\n  \"phone\": \"01800000000\"\n}" },
            "url": "{{baseUrl}}/api/v1/users/me",
            "description": "Role: Auth"
          }
        }
      ]
    },
    {
      "name": "Messes",
      "item": [
        {
          "name": "Create Mess",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"My Mess\",\n  \"address\": \"Dhaka\",\n  \"settings\": {}\n}" },
            "url": "{{baseUrl}}/api/v1/messes",
            "description": "Role: Auth (validation is any/placeholder)"
          }
        },
        {
          "name": "Join Mess (Request)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"inviteCode\": \"ABC123\"\n}" },
            "url": "{{baseUrl}}/api/v1/messes/join",
            "description": "Role: Auth (validation is any/placeholder)"
          }
        },
        { "name": "Get Mess", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}", "description": "Role: Member+" } },
        {
          "name": "Update Mess",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Mess Name\"\n}" },
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}",
            "description": "Role: Manager (validation is any/placeholder)"
          }
        },
        { "name": "Regenerate Invite Code", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/regenerate-invite-code", "description": "Role: Manager" } },
        {
          "name": "Transfer Ownership",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"newManagerMemberId\": \"{{memberId}}\"\n}" },
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/transfer-ownership",
            "description": "Role: Manager (validation is any/placeholder)"
          }
        }
      ]
    },
    { "name": "Mess Members", "item": [
      { "name": "Get Members", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/members", "description": "Role: Member+" } },
      { "name": "Approve Member", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/members/{{memberId}}/approve", "description": "Role: Member+ (route does not enforce manager explicitly)" } },
      { "name": "Reject Member", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/members/{{memberId}}/reject", "description": "Role: Member+ (route does not enforce manager explicitly)" } },
      { "name": "Remove Member", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/members/{{memberId}}/remove", "description": "Role: Member+ (route does not enforce manager explicitly)" } }
    ] },
    { "name": "Payments", "item": [
      { "name": "List Payments", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments", "description": "Role: Member+" } },
      { "name": "Create Payment", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"messMemberId\": \"{{memberId}}\",\n  \"amount\": 500,\n  \"method\": \"cash\",\n  \"reference\": \"optional-note\"\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments", "description": "Role: Member+" } },
      { "name": "Get My Payments", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments/me", "description": "Role: Member+" } },
      { "name": "Get Payment By Id", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments/{{paymentId}}", "description": "Role: Member+" } },
      { "name": "Approve Payment", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments/{{paymentId}}/approve", "description": "Role: Manager" } },
      { "name": "Reject Payment", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments/{{paymentId}}/reject", "description": "Role: Manager" } },
      { "name": "Cancel Payment", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments/{{paymentId}}/cancel", "description": "Role: Member+" } }
    ] },
    { "name": "Expenses", "item": [
      { "name": "List Expenses", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses", "description": "Role: Member+" } },
      { "name": "Create Expense", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"category\": \"grocery\",\n  \"amount\": 1200,\n  \"date\": \"2025-01-01T00:00:00.000Z\",\n  \"paidBy\": \"{{memberId}}\",\n  \"fundSource\": \"mess_cash\",\n  \"receiptUrl\": \"https://example.com/receipt.png\"\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses", "description": "Role: Member+" } },
      { "name": "Get Expense By Id", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses/{{expenseId}}", "description": "Role: Member+" } },
      { "name": "Approve Expense", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses/{{expenseId}}/approve", "description": "Role: Manager" } },
      { "name": "Reject Expense", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses/{{expenseId}}/reject", "description": "Role: Manager" } },
      { "name": "Reimburse Expense", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses/{{expenseId}}/reimburse", "description": "Role: Manager" } },
      { "name": "Cancel/Delete Expense", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses/{{expenseId}}", "description": "Role: Member+" } }
    ] },
    { "name": "Billing", "item": [
      { "name": "Get Billing Cycles", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/billing", "description": "Role: Member+" } },
      { "name": "Get Member Bills", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/billing/{{billingCycleId}}/members", "description": "Role: Member+" } },
      { "name": "Preview Billing", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"month\": 1,\n  \"year\": 2025\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/billing/preview", "description": "Role: Manager" } },
      { "name": "Finalize Billing", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"month\": 1,\n  \"year\": 2025\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/billing/finalize", "description": "Role: Manager" } },
      { "name": "Reopen Billing", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/billing/{{billingCycleId}}/reopen", "description": "Role: Manager" } }
    ] },
    { "name": "Meals", "item": [
      { "name": "List Meals", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/meals", "description": "Role: Member+" } },
      { "name": "Log Meal", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"messMemberId\": \"{{memberId}}\",\n  \"date\": \"2025-01-01T00:00:00.000Z\",\n  \"mealCount\": 1\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/meals", "description": "Role: Manager" } }
    ] },
    { "name": "Meal Off Requests", "item": [
      { "name": "List Requests", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/meal-off-requests", "description": "Role: Member+" } },
      { "name": "Create Request", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"messMemberId\": \"{{memberId}}\",\n  \"startDate\": \"2025-01-01\",\n  \"endDate\": \"2025-01-03\",\n  \"reason\": \"Travel\"\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/meal-off-requests", "description": "Role: Member+" } },
      { "name": "Approve Request", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/meal-off-requests/{{requestId}}/approve", "description": "Role: Manager" } },
      { "name": "Reject Request", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/meal-off-requests/{{requestId}}/reject", "description": "Role: Manager" } }
    ] },
    { "name": "Utility Bills", "item": [
      { "name": "List Utility Bills", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/utility-bills", "description": "Role: Member+" } },
      { "name": "Create Utility Bill", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"category\": \"electricity\",\n  \"amount\": 2500,\n  \"billingMonth\": 1,\n  \"year\": 2025,\n  \"dueDate\": \"2025-02-01T00:00:00.000Z\"\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/utility-bills", "description": "Role: Manager. Body: { category, amount, billingMonth(1-12), year, dueDate? }." } },
      { "name": "Mark Paid", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/utility-bills/{{billId}}/pay", "description": "Role: Manager" } }
    ] },
    { "name": "Market Schedules", "item": [
      { "name": "Get Schedules", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/market-schedules", "description": "Role: Member+" } },
      { "name": "Get My Duties", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/market-schedules/my-duties", "description": "Role: Member+" } },
      { "name": "Create Schedule", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"assignedTo\": [\"{{memberId}}\"],\n  \"targetDate\": \"2025-01-01T00:00:00.000Z\",\n  \"shoppingItems\": [{\"name\": \"Rice\", \"quantity\": \"5kg\"}],\n  \"estimatedBudget\": 2000\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/market-schedules", "description": "Role: Manager" } },
      { "name": "Update Schedule", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"estimatedBudget\": 2500\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/market-schedules/{{scheduleId}}", "description": "Role: Manager" } },
      { "name": "Reassign", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"assignedTo\": [\"{{memberId}}\"]\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/market-schedules/{{scheduleId}}/reassign", "description": "Role: Manager" } },
      { "name": "Update Spent", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"actualSpent\": 1800\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/market-schedules/{{scheduleId}}/spent", "description": "Role: Member+" } },
      { "name": "Complete", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"actualSpent\": 1800,\n  \"actorMessMemberId\": \"{{memberId}}\",\n  \"fundSource\": \"mess_cash\"\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/market-schedules/{{scheduleId}}/complete", "description": "Role: Member+" } },
      { "name": "Void", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/market-schedules/{{scheduleId}}/void", "description": "Role: Manager" } }
    ] },
    { "name": "Menu Plans", "item": [
      { "name": "Get Menu Plans", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/menu-plans", "description": "Role: Member+" } },
      { "name": "Get By Date", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/menu-plans/date/2025-01-01", "description": "Role: Member+" } },
      { "name": "Get By Id", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/menu-plans/{{planId}}", "description": "Role: Member+" } },
      { "name": "Create Menu Plan", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"date\": \"2025-01-01T00:00:00.000Z\",\n  \"meals\": {\n    \"breakfast\": \"Egg\",\n    \"lunch\": \"Rice\",\n    \"dinner\": \"Fish\"\n  },\n  \"isAiGenerated\": false\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/menu-plans", "description": "Role: Manager" } },
      { "name": "Update Menu Plan", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"meals\": {\n    \"lunch\": \"Chicken\"\n  }\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/menu-plans/{{planId}}", "description": "Role: Manager" } },
      { "name": "Publish", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/menu-plans/{{planId}}/publish", "description": "Role: Manager" } },
      { "name": "Archive", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/menu-plans/{{planId}}/archive", "description": "Role: Manager" } }
    ] },
    { "name": "AI Shopping", "item": [
      { "name": "Get Lists", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/ai-shopping", "description": "Role: Member+" } },
      { "name": "Get List By Id", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/ai-shopping/{{listId}}", "description": "Role: Member+" } },
      { "name": "Generate", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"menuPlanId\": \"{{planId}}\",\n  \"targetDate\": \"2025-01-01T00:00:00.000Z\"\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/ai-shopping/generate", "description": "Role: Manager" } },
      { "name": "Approve", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/ai-shopping/{{listId}}/approve", "description": "Role: Manager" } },
      { "name": "Reject", "request": { "method": "POST", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/ai-shopping/{{listId}}/reject", "description": "Role: Manager" } },
      { "name": "Convert", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"assignedTo\": [\"{{memberId}}\"],\n  \"estimatedBudget\": 2000\n}" }, "url": "{{baseUrl}}/api/v1/messes/{{messId}}/ai-shopping/{{listId}}/convert", "description": "Role: Manager" } }
    ] },
    { "name": "Notices", "item": [
      { "name": "List Notices", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/notices", "description": "Role: Member+" } },
      { "name": "Get Notice", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/messes/{{messId}}/notices/{{noticeId}}", "description": "Role: Member+" } },
