    {
      "name": "Utility Bills",
      "description": "Utility bill tracking. Managers create bills and mark as paid.",
      "item": [
        {
          "name": "List Utility Bills",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/utility-bills",
