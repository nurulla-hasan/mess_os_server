{
  "info": {
    "_postman_id": "2b7d6c7f-0f6f-4f62-9e5b-7c1a2b1f8f0a",
    "name": "MessManagerOS API (v1)",
    "description": "Complete Postman collection for MessManagerOS API. 85+ requests covering all modules: auth, users, mess, mess-member, payments, expenses, billing, meals, meal-off-requests, utility-bills, market-schedules, menu-plans, ai-shopping, notices, complaints, reports, subscriptions, and admin.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "messId", "value": "", "type": "string" },
    { "key": "memberId", "value": "", "type": "string" },
    { "key": "paymentId", "value": "", "type": "string" },
    { "key": "expenseId", "value": "", "type": "string" },
    { "key": "billingCycleId", "value": "", "type": "string" },
    { "key": "requestId", "value": "", "type": "string" },
    { "key": "billId", "value": "", "type": "string" },
    { "key": "scheduleId", "value": "", "type": "string" },
    { "key": "planId", "value": "", "type": "string" },
    { "key": "listId", "value": "", "type": "string" },
    { "key": "noticeId", "value": "", "type": "string" },
    { "key": "complaintId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) pm.collectionVariables.set('baseUrl', 'http://localhost:5000');",
          "if (!pm.collectionVariables.get('accessToken')) pm.collectionVariables.set('accessToken', '');"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints. Public routes require no auth. Change password requires authentication.",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"01700000000\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register",
            "description": "Role: Public. Body: { fullName (string, required), email (string, required), password (string, min 6, required), phone (string, optional) }"
          }
        },
        {
          "name": "Login (Saves accessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "try { const json = pm.response.json(); const token = json?.data?.accessToken; if (token) { pm.collectionVariables.set('accessToken', token); console.log('Token saved to collection variable'); } } catch (e) { console.error('Failed to parse token', e); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "Role: Public. Rate limited. Body: { email (string, required), password (string, required) }. Returns accessToken in response, refreshToken in HTTP-only cookie."
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/verify-email",
            "description": "Role: Public. Rate limited. Body: { email (string, required), otp (string, length 6, required) }"
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/resend-otp",
            "description": "Role: Public. Strict rate limited. Body: { email (string, required) }"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Cookie", "value": "refreshToken={{refreshToken}}", "type": "text", "disabled": true }],
            "url": "{{baseUrl}}/api/v1/auth/refresh-token",
            "description": "Role: Public (requires valid refreshToken in HTTP-only cookie). Returns new accessToken. Postman automatically sends cookies."
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/logout",
            "description": "Role: Public. Clears refreshToken cookie on server side."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/forgot-password",
            "description": "Role: Public. Rate limited. Body: { email (string, required) }"
          }
        },
        {
          "name": "Verify Reset OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/verify-reset-otp",
            "description": "Role: Public. Rate limited. Body: { email (string, required), otp (string, length 6, required) }"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"password1234\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/reset-password",
            "description": "Role: Public. Rate limited. Body: { email (string, required), otp (string, length 6, required), newPassword (string, min 6, required) }"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"password123\",\n  \"newPassword\": \"password1234\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/change-password",
            "description": "Role: Auth (requires bearer token). Body: { oldPassword (string, required), newPassword (string, min 6, required) }"
          }
        }
      ]
    },
    {
      "name": "Users",
      "description": "User profile management. All routes require authentication.",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me",
            "description": "Role: Auth. Returns current user profile."
          }
        },
        {
          "name": "Update Me",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Updated Name\",\n  \"phone\": \"01800000000\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/users/me",
            "description": "Role: Auth. Body: { fullName (string, optional), phone (string, optional) }"
          }
        }
      ]
    },
    {
      "name": "Messes",
      "description": "Mess management. Create, join, update mess. All routes require authentication. Routes under /:messId require mess membership (Manager or Member).",
      "item": [
        {
          "name": "Create Mess",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Mess\",\n  \"address\": \"Dhaka\",\n  \"settings\": {}\n}"
            },
            "url": "{{baseUrl}}/api/v1/messes",
            "description": "Role: Auth. Creates new mess and sets creator as manager. Body schema: any (placeholder validation)"
          }
        },
        {
          "name": "Join Mess (Request)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inviteCode\": \"ABC123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/messes/join",
            "description": "Role: Auth. Joins mess using invite code. Body schema: any (placeholder validation)"
          }
        },
        {
          "name": "Get Mess",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}",
            "description": "Role: Member+ (Manager/Member). Returns mess details. Requires messId variable."
          }
        },
        {
          "name": "Update Mess",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Mess Name\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}",
            "description": "Role: Manager only. Body schema: any (placeholder validation). Requires messId variable."
          }
        },
        {
          "name": "Regenerate Invite Code",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/regenerate-invite-code",
            "description": "Role: Manager only. Generates new invite code for mess. Requires messId variable."
          }
        },
        {
          "name": "Transfer Ownership",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newManagerMemberId\": \"{{memberId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/transfer-ownership",
            "description": "Role: Manager only. Transfers manager role to another member. Body schema: any (placeholder validation). Requires messId and memberId variables."
          }
        }
      ]
    },
    {
      "name": "Mess Members",
      "description": "Member management within a mess. Note: These routes don't explicitly enforce manager role in route file - parent mess context applies.",
      "item": [
        {
          "name": "Get Members",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/members",
            "description": "Role: Member+. Lists all mess members. Requires messId variable."
          }
        },
        {
          "name": "Approve Member",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/members/{{memberId}}/approve",
            "description": "Role: Manager. Approves pending join request. Requires messId and memberId variables."
          }
        },
        {
          "name": "Reject Member",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/members/{{memberId}}/reject",
            "description": "Role: Manager. Rejects pending join request. Requires messId and memberId variables."
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/members/{{memberId}}/remove",
            "description": "Role: Manager. Removes member from mess. Requires messId and memberId variables."
          }
        }
      ]
    },
    {
      "name": "Payments",
      "description": "Payment management. Members can create payments, managers can approve/reject.",
      "item": [
        {
          "name": "List Payments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments",
            "description": "Role: Member+. Lists all payments in mess. Requires messId variable."
          }
        },
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messMemberId\": \"{{memberId}}\",\n  \"amount\": 5000,\n  \"method\": \"cash\",\n  \"reference\": \"January payment\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments",
            "description": "Role: Member+. Creates payment record. Body: { messMemberId (ObjectId, required), amount (number, positive, required), method (string, required), reference (string, optional) }"
          }
        },
        {
          "name": "Get My Payments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments/me",
            "description": "Role: Member+. Lists current user's payments. Requires messId variable."
          }
        },
        {
          "name": "Get Payment By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments/{{paymentId}}",
            "description": "Role: Member+. Gets payment details. Requires messId and paymentId variables."
          }
        },
        {
          "name": "Approve Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments/{{paymentId}}/approve",
            "description": "Role: Manager. Approves pending payment. Requires messId and paymentId variables."
          }
        },
        {
          "name": "Reject Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments/{{paymentId}}/reject",
            "description": "Role: Manager. Rejects pending payment. Requires messId and paymentId variables."
          }
        },
        {
          "name": "Cancel Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/payments/{{paymentId}}/cancel",
            "description": "Role: Member+. Cancels own payment. Requires messId and paymentId variables."
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "description": "Expense tracking. Members can create expenses, managers approve/reject/reimburse.",
      "item": [
        {
          "name": "List Expenses",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses",
            "description": "Role: Member+. Lists all expenses. Requires messId variable."
          }
        },
        {
          "name": "Create Expense",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"grocery\",\n  \"amount\": 1200,\n  \"date\": \"2025-01-01T00:00:00.000Z\",\n  \"paidBy\": \"{{memberId}}\",\n  \"fundSource\": \"mess_cash\",\n  \"receiptUrl\": \"https://example.com/receipt.png\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses",
            "description": "Role: Member+. Body: { category (string, required), amount (number, positive, required), date (ISO datetime, required), paidBy (ObjectId, required), fundSource ('mess_cash'|'personal_cash', required), receiptUrl (URL, optional) }"
          }
        },
        {
          "name": "Get Expense By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses/{{expenseId}}",
            "description": "Role: Member+. Gets expense details. Requires messId and expenseId variables."
          }
        },
        {
          "name": "Approve Expense",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses/{{expenseId}}/approve",
            "description": "Role: Manager. Approves expense. Requires messId and expenseId variables."
          }
        },
        {
          "name": "Reject Expense",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses/{{expenseId}}/reject",
            "description": "Role: Manager. Rejects expense. Requires messId and expenseId variables."
          }
        },
        {
          "name": "Reimburse Expense",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses/{{expenseId}}/reimburse",
            "description": "Role: Manager. Marks expense as reimbursed. Requires messId and expenseId variables."
          }
        },
        {
          "name": "Cancel Expense",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/expenses/{{expenseId}}",
            "description": "Role: Member+. Deletes/cancels own expense. Requires messId and expenseId variables."
          }
        }
      ]
    },
    {
      "name": "Billing",
