              "raw": "{\n  \"category\": \"electricity\",\n  \"amount\": 2500,\n  \"billingMonth\": 1,\n  \"year\": 2025,\n  \"dueDate\": \"2025-02-01T00:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/messes/{{messId}}/utility-bills",
